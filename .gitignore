# Miscellaneous
*.class
*.log
*.pyc
*.swp

# Prebake network cache — local artifact, never committed (Story 1.3, AD-8).
# Note: the GENERATED assets (assets/db/foresight.db, assets/sprites/*.png) ARE
# committed so a clone builds offline without re-running the network prebake.
prebake/.cache/
__pycache__/
.pytest_cache/
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# --- Foresight: keep internal planning/tooling out of the public repo ---
# BMAD planning artifacts, specs, sprint tracking, stories — internal, not shipped.
/_bmad-output/
# BMAD module config + scripts (contains local setup/identity) and installed skills.
/_bmad/
/.claude/
